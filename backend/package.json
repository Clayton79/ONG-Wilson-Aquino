{
  "name": "cufa-pernambuco-backend",
  "version": "1.0.0",
  "description": "Backend API for CUFA Pernambuco management system",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run seed:prod",
    "start": "node dist/index.js",
    "seed": "tsx src/utils/seed.ts",
    "seed:prod": "node dist/utils/seed.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.5.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0"
  }
}
